Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On

# Deny direct web access to sensitive files/folders.
# (PHP includes still work; only HTTP requests are blocked.)
RewriteRule ^(?:env\.hostinger|\.env)$ - [F,L,NC]
RewriteRule ^config/ - [F,L,NC]
RewriteRule ^storage/ - [F,L,NC]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Public API routes
RewriteRule ^api/(.+)$ api/$1 [L,QSA,NC]

# Fallback to app entry point
RewriteRule . index.php [L]